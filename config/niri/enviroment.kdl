
environment {
	LANG "zh_CN.UTF-8"
	LC_CTYPE "en_US.UTF-8"

	QT_QPA_PLATFORMTHEME "qt6ct"
    XDG_CURRENT_DESKTOP "niri"
	QT_IM_MODULES "wayland;fcitx" //中文输入法支持,
    QT_IM_MODULE "fcitx"
	XMODIFIERS "@im=fcitx"
	QT_QPA_PLATFORM "wayland;xcb" 
	ELECTRON_OZONE_PLATFORM_HINT "auto"// Electron > 28应用支持
		// QQ的Electron不响应ELECTRON_OZONE_PLATFORM_HINT环境变量，需用 ~/.config/qq-flags.conf 传入wayland参数



}

